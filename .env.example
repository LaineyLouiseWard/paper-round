# Copy this file to .env and fill in what you use. The .env file is
# gitignored; never commit keys. screen.py loads it automatically.

# Zotero Web API key with write access to your target library
# (create at zotero.org/settings/keys). Leave unset to skip Zotero
# entirely and curate from the email digest instead.
ZOTERO_API_KEY=

# Resend API key for the emailed digest (free account at resend.com)
RESEND_API_KEY=

# Only needed for local screening runs; the cloud routine screens natively
ANTHROPIC_API_KEY=

# Only needed if config.yaml lists openalex_sources. Free key from
# openalex.org; anonymous access is heavily rate-limited.
OPENALEX_API_KEY=
